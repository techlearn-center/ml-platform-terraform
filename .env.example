# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_PROFILE=ml-platform

# Terraform Backend
TF_STATE_BUCKET=ml-platform-tfstate
TF_STATE_LOCK_TABLE=ml-platform-tflock
TF_STATE_REGION=us-east-1

# Project Settings
PROJECT_NAME=ml-platform
ENVIRONMENT=dev

# SageMaker Configuration
SAGEMAKER_NOTEBOOK_INSTANCE_TYPE=ml.t3.medium
SAGEMAKER_TRAINING_INSTANCE_TYPE=ml.m5.xlarge
SAGEMAKER_ENDPOINT_INSTANCE_TYPE=ml.m5.large

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_BUCKET=ml-platform-mlflow-artifacts
MLFLOW_DB_HOST=localhost
MLFLOW_DB_PORT=5432
MLFLOW_DB_NAME=mlflow
MLFLOW_DB_USERNAME=mlflow
MLFLOW_DB_PASSWORD=changeme

# Data Lake
DATA_LAKE_BUCKET=ml-platform-data-lake
FEATURE_STORE_BUCKET=ml-platform-feature-store
MODEL_ARTIFACTS_BUCKET=ml-platform-model-artifacts

# Monitoring
ALERT_EMAIL=ml-team@example.com
COST_ALERT_THRESHOLD=500
